# ─────────────────────────────────────────────────────────────────────────────
# Local development env — copy to `.env.local` and fill in.
#
#   cp .env.local.example .env.local
#
# Sources:
#   [local]      Supabase local stack defaults (after `supabase start`).
#   [vercel]     Pulled by `vercel env pull .env.local` (preview/prod scopes).
#   [manual]     Set by hand.
#
# Production / Preview values are injected by Vercel per environment —
# never commit real secrets to this file or to `.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# ---- Supabase ---------------------------------------------------------------
# [local] After `supabase start`, the CLI prints these. Defaults are stable:
#   API URL        : http://127.0.0.1:54321
#   anon key       : printed by `supabase status` (field: "anon key")
# For preview/prod, use `vercel env pull` instead of hand-copying.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ---- Site URL ---------------------------------------------------------------
# [manual — local] http://localhost:3000 for `vercel dev` / `next dev`.
# [vercel]         Set per-scope in Vercel Dashboard → Environment Variables.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Feature gates ----------------------------------------------------------
# [manual] Leave unset to enable Google OAuth; set to "false" to hide the button.
# NEXT_PUBLIC_ENABLE_GOOGLE_OAUTH=

# ---- MCP (Model Context Protocol) ------------------------------------------
# The /api/mcp route uses the app's normal Supabase env above — no dedicated
# variable. Supabase acts as the OAuth 2.1 Authorization Server; the toggle
# lives in supabase/config.toml (`[auth.oauth_server]`) locally and in
# Dashboard → Authentication → OAuth Server in staging / prod.
# See docs/mcp.md for the client setup snippet (Claude Desktop / web).

# ---- Logging (consumed by lib/logger.ts — built in Phase 3) -----------------
# [manual] Levels: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug
# Pretty-print logs to stdout locally via pino-pretty. Set "false" in prod.
LOG_PRETTY=true

# ---- E2E staging (CI only) --------------------------------------------------
# Consumed by tests/e2e/auth-staging.spec.ts. Tests skip if unset.
E2E_BASE_URL=
E2E_SUPABASE_URL=
E2E_SUPABASE_PUBLISHABLE_KEY=
E2E_TEST_USER_EMAIL=
E2E_TEST_USER_PASSWORD=
