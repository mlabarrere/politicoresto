# Supabase project — choose the ref matching your target environment:
#   - Production (Vercel Production) : projet Supabase prod
#   - Preview     (Vercel Preview)    : projet staging (nvwpvckjsvicsyzpzjfi)
#   - Local dev   (.env.local)        : staging OU instance locale `supabase start`
#
# Env vars are configured per environment in Vercel Dashboard
# → Settings → Environment Variables. Le code ne fait aucun switch manuel.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# URL canonique du déploiement — set par Vercel par scope. Utilisée pour les
# logs et les liens canoniques. L'OAuth utilise window.location.origin (pattern
# Supabase standard), donc ce n'est pas requis pour le login fonctionne.
#   - Preview     : https://politicoresto-staging.vercel.app
#   - Production  : https://politicoresto.vercel.app
NEXT_PUBLIC_SITE_URL=

# -------- E2E staging (CI uniquement) --------
# Secrets utilisés par tests/e2e/auth-staging.spec.ts. Skipped si absents.
E2E_BASE_URL=
E2E_SUPABASE_URL=
E2E_SUPABASE_PUBLISHABLE_KEY=
E2E_TEST_USER_EMAIL=
E2E_TEST_USER_PASSWORD=
